# OpenAI API key (or compatible provider key used by the OpenAI SDK)
OPENAI_API_KEY=sk-...

# Serper.dev API key for Google search results
SERPER_API_KEY=...

# AlphaXiv MCP server URL (see https://www.alphaxiv.org/docs/mcp)
# Requires Node.js (npx) -- the agent runs `npx mcp-remote <url>` as a
# bridge, which handles the OAuth login (opens a browser the first time).
ALPHAXIV_MCP_URL=https://api.alphaxiv.org/mcp/v1

# Max tokens for each model response (lower this if you hit credit limits)
AGENT_MAX_TOKENS=1000

# Optional: set this to use an OpenAI-compatible provider like OpenRouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model to use (must support tool/function calling)
AGENT_MODEL=openrouter/free